{
  "schemaVersion": 1,
  "id": "copy-book",
  "version": "${version}",
  "name": "Copy Book",
  "description": "A Meteor Client addon for copying books.",
  "authors": [
    "MrAngalo"
  ],
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "me.book.copy.CopyBook"
    ]
  },
  "mixins": [
    "copy-book.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
